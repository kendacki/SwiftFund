NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Hedera account used by SDK scripts (ED25519 DER)
HEDERA_TESTNET_ACCOUNT_ID=0.0.xxxxxx
HEDERA_TESTNET_PRIVATE_KEY=302e02...

# Optional: Hedera ECDSA private key (0x...) for JSON-RPC / Hardhat deployments
# HEDERA_ECDSA_PRIVATE_KEY=0x...

# SWIND token + oracle topic
NEXT_PUBLIC_SWIND_TOKEN_ID=0.0.xxxxxx
NEXT_PUBLIC_AGENT_TOPIC_ID=0.0.xxxxxx

# SwiftFund treasury contract ID (0.0.x from HashScan)
NEXT_PUBLIC_TREASURY_CONTRACT_ID=0.0.xxxxxx

# Fan accounts and payout settings
FAN_ACCOUNT_IDS=0.0.xxxxxx
TREASURY_AMOUNT_PER_FAN_WEI=1000000000000000
SWIND_AMOUNT_PER_FAN=100

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Vercel Blob (profile avatar storage). Create a Blob store in Vercel project → Storage.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
BLOB_READ_WRITE_TOKEN=

# Supabase (project storage and approvals). Create a project at supabase.com, then run supabase/migrations/001_projects.sql in SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Approver secret: required to call POST /api/projects/approve (header: x-approver-secret). Only you should approve projects.
APPROVER_SECRET=
